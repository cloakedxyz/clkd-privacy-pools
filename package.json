{
  "name": "@cloakedxyz/clkd-privacy-pools",
  "version": "2.1.0",
  "description": "Privacy Pools key derivation, proof generation, and recovery tools for Cloaked",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky && tsc -p tsconfig.build.json"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "privacy-pools",
    "0xbow",
    "zk-proofs",
    "groth16",
    "ethereum",
    "stealth-addresses",
    "cloaked"
  ],
  "author": "Cloaked",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloakedxyz/clkd-privacy-pools.git"
  },
  "bugs": {
    "url": "https://github.com/cloakedxyz/clkd-privacy-pools/issues"
  },
  "homepage": "https://github.com/cloakedxyz/clkd-privacy-pools#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.18.0",
  "dependencies": {
    "@0xbow/privacy-pools-core-sdk": "1.2.0",
    "maci-crypto": "2.5.0",
    "viem": "^2.39.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.10"
  }
}
